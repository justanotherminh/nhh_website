# Copy to .env and fill in. Values here are safe local-dev defaults.

APP_NAME=NHH 2026
BASE_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-long-random-string

# Database (matches docker-compose)
DATABASE_URL=postgresql+psycopg://nhh:nhh@localhost:5433/nhh

# payOS credentials (from your payOS merchant dashboard) — DO NOT commit real values
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
# Set true to simulate payment in-app (no real payOS call). Keep false in production.
PAYMENTS_DEV_MODE=false

# SMTP — defaults target the Mailpit container (view mail at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=NHH 2026 <noreply@nhh.local>

# Seat holds
HOLD_TTL_SECONDS=600
PAYMENT_WINDOW_SECONDS=900
MAX_SEATS_PER_ORDER=8

# Admin dashboard (HTTP basic auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
