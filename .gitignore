# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment / secrets
.env
.env.*
!.env.example
!.env.prod.example

# Claude local settings (personal, not shared)
.claude/settings.local.json

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local data / artifacts
*.sqlite3
*.db
caddy_data/
postgres_data/

# Design source assets (large working files at repo root; the optimized
# derivatives the site actually serves live under app/static/img/ and ARE tracked)
/*.png
/*.jpg
/*.jpeg
/*.webp
/*.psd
/*.ai

# Working spreadsheets may contain budget / personnel / guest PII (e.g. the project
# masterplan). Keep them out of git and the Docker image. The seat-map source
# workbook is already tracked (the importer needs it) and this rule can't untrack it;
# the reserved-seat list we DO ship lives in scripts/data/vip_reserved_seats.csv.
*.xlsx

# Manager-uploaded images (persistent volume in prod; runtime data, never committed)
app/static/uploads/
