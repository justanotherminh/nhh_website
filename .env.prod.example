# Production environment. On the server: `cp .env.prod.example .env` then fill in.
# This file is read BOTH by docker-compose (for ${...} substitution) and by the
# app container (env_file). NEVER commit the filled-in .env.

# --- App ---
APP_NAME=NHH 2026
BASE_URL=https://www.nanghoanghon.org
# Generate a strong one:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# --- Database (Postgres runs in the `db` container; host is the service name) ---
POSTGRES_USER=nhh
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=nhh
DATABASE_URL=postgresql+psycopg://nhh:CHANGE_ME_strong_db_password@db:5432/nhh

# --- payOS (SANDBOX credentials for now; swap to production when ready) ---
PAYOS_CLIENT_ID=your-payos-sandbox-client-id
PAYOS_API_KEY=your-payos-sandbox-api-key
PAYOS_CHECKSUM_KEY=your-payos-sandbox-checksum-key
# false = use the real payOS gateway (sandbox counts as real). true = in-app simulator.
PAYMENTS_DEV_MODE=false

# --- SMTP (real e-ticket email) ---
# Example for Gmail: host smtp.gmail.com, port 587, TLS on, user = full address,
# password = a Google "App Password" (not your login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=NHH 2026 <your-address@gmail.com>
SMTP_USE_TLS=true

# --- Seat holds ---
HOLD_TTL_SECONDS=600
PAYMENT_WINDOW_SECONDS=900
MAX_SEATS_PER_ORDER=8

# --- Admin dashboard (Phase 6; harmless to set now) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- Door check-in (limited credential for entrance volunteers) ---
# Can scan/redeem tickets but NOT see the admin dashboard. Safe to hand out.
CHECKIN_USERNAME=cua
CHECKIN_PASSWORD=CHANGE_ME_checkin_password

# --- Early-bird discount ---
# Managed at runtime from the admin UI (Bảng quản trị → Ưu đãi), stored in the
# database — no env var or restart needed.
